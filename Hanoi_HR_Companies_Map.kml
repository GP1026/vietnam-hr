<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>河内 HR 招聘公司地图</name>
    <description>越南河内主要HR/招聘公司位置，用于帮助中国企业招聘懂中文越南本地员工的调研。数据核实时间：2026年4月13日。共28家。</description>

    <!-- 样式定义：蓝色 = 国际连锁，红色 = 越南本土 -->
    <Style id="international">
      <IconStyle>
        <color>ffff5500</color>
        <scale>1.2</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/ms/icons/blue-dot.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <color>ffff5500</color>
      </LabelStyle>
    </Style>

    <Style id="local">
      <IconStyle>
        <color>ff0000ff</color>
        <scale>1.2</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/ms/icons/red-dot.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <color>ff0000ff</color>
      </LabelStyle>
    </Style>

